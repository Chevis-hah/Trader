# ============================================================
# Trader 环境变量示例
# ============================================================
# 使用方法:
#   cp .env.example .env
#   # 编辑 .env 填入真实 key
#
# 代码中加载:
#   import os
#   key = os.getenv("BINANCE_API_KEY")
#
# .env 已在 .gitignore 中, 不会被提交
# ============================================================

# ------------------------------------------------------------
# Binance (Phase 2A Funding Harvester / 实盘必填)
# ------------------------------------------------------------
# 测试网首选: https://testnet.binance.vision/  (spot)
#             https://testnet.binancefuture.com/ (perp)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true            # true=testnet, false=mainnet

# ------------------------------------------------------------
# CryptoQuant (Phase 4 On-chain 因子)
# 订阅: https://cryptoquant.com/  基础版 $99/mo
# ------------------------------------------------------------
CRYPTOQUANT_API_KEY=

# ------------------------------------------------------------
# CoinGlass (Phase 2A funding/OI 补充 + Phase 3 期货基差)
# 订阅: https://www.coinglass.com/  $49/mo
# ------------------------------------------------------------
COINGLASS_API_KEY=

# ------------------------------------------------------------
# 系统
# ------------------------------------------------------------
LOG_LEVEL=INFO                  # DEBUG / INFO / WARNING / ERROR
DB_PATH=data/quant.db
